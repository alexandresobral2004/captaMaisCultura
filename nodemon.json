{
  "watch": ["app/**/*.{ts,tsx}", "lib/**/*.{ts,tsx}", "components/**/*.{ts,tsx}"],
  "ext": "ts,tsx",
  "ignore": [
    "node_modules/**",
    ".next/**",
    "data/**",
    "logs/**",
    "__tests__/**",
    "*.test.ts",
    "*.spec.ts"
  ],
  "exec": "next dev",
  "delay": 1500,
  "env": {
    "NODE_ENV": "development"
  }
}
