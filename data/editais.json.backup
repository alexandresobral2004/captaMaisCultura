  {
    "statusAnalise": "pendente",
    "id": "prosas-18081",
    "titulo": "Edital Culturas Populares, Mestres e Comunidades Tradicionais",
    "orgao": "Secretaria Municipal de Cultura e Economia Criativa de Nossa Senhora do Socorro",
    "valor": "R$ 300000.0",
    "valorMax": null,
    "dataLimite": "2026-06-02",
    "status": "Aberto",
    "link": "https://www.socorro.se.gov.br/sites/socorro.se.gov.br/files/EDITAL%20N%C2%B0%200022026%20EDITAL%20CULTURA%20POPULARES%2C%20MESTRES%20E%20COMUNIDADES%20TRADICIONAIS..pdf",
    "descricao": "<p>O edital tem como propósito central a salvaguarda e o fortalecimento do património cultural imaterial de Nossa Senhora do Socorro. O foco está no apoio a iniciativas que garantam a transmissão de saberes tradicionais entre gerações, promovam as expressões artísticas da cultura popular e protejam as manifestações de grupos historicamente vulnerabilizados, impulsionando a economia criativa local e a descentralização territorial.</p><p>As propostas devem estar alinhadas com a preservação de tradições, incluindo:</p><p>- Culturas populares e identitárias locais;</p><p>- Celebrações, rituais, festejos tradicionais e folclore;</p><p>- Práticas e saberes de Mestres e Mestras da cultura tradicional;</p><p>- Expressões culturais de comunidades tradicionais (como quilombolas, povos de terreiro, entre outros).</p><p>A inscrição é gratuita, exigindo o preenchimento do formulário de inscrição, a entrega do Plano de Trabalho detalhado e o portefólio que comprove a atuação do agente na cultura popular.</p>",
    "criadoEm": "2026-05-29T17:43:42.642Z",
    "arquivosAnexos": [
      {
        "descricao": "Arquivo",
        "url": "https://prosas-prod-files.s3.sa-east-1.amazonaws.com/arquivos/arquivos/004/834/380/original/EDITAL_N%C2%B0_0022026_EDITAL_CULTURA_POPULARES__MESTRES_E_COMUNIDADES_TRADICIONAIS.pdf?X-Amz-Algorithm=AWS4-HMAC-SHA256&X-Amz-Credential=AKIAUS3M5UKOOGXP27N7%2F20260529%2Fsa-east-1%2Fs3%2Faws4_request&X-Amz-Date=20260529T174341Z&X-Amz-Expires=3600&X-Amz-SignedHeaders=host&X-Amz-Signature=df9efa012c0d98ccb53b76654dd6c9ae33b1f405f646da7d1dc635eb23ee4ef7",
        "tipo": "arquivo"
      }
    ],
