  {
    "statusAnalise": "pendente",
    "id": "prosas-17450",
    "titulo": "Edital De Chamamento Público PNAB Nº 02/2026 Premiação Cultural Contagem",
    "orgao": "Prosas",
    "valor": "Até R$ 4500.0",
    "valorMax": "4500.0",
